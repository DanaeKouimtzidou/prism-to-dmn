<?xml version="1.0" ?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="def_e42763b9-4911-4a2d-9465-39ce2099bf9f" name="PRISM Decision Table" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="dec_2966f2f8-4063-47bc-8c68-6ff2cd6160f0" name="PRISM Decision Table">
    <decisionTable id="dt_484e147c-199b-4f07-a253-7050728c718e" hitPolicy="FIRST">
      <input>
        <inputExpression typeRef="string">
          <text>Humidity</text>
        </inputExpression>
      </input>
      <input>
        <inputExpression typeRef="string">
          <text>Outlook</text>
        </inputExpression>
      </input>
      <input>
        <inputExpression typeRef="string">
          <text>Wind</text>
        </inputExpression>
      </input>
      <output name="PlayTennis" typeRef="string"/>
      <rule>
        <inputEntry>
          <text>&quot;High&quot;</text>
        </inputEntry>
        <inputEntry>
          <text>&quot;Sunny&quot;</text>
        </inputEntry>
        <inputEntry>
          <text>-</text>
        </inputEntry>
        <outputEntry>
          <text>No</text>
        </outputEntry>
      </rule>
      <rule>
        <inputEntry>
          <text>&quot;High&quot;</text>
        </inputEntry>
        <inputEntry>
          <text>&quot;Rain&quot;</text>
        </inputEntry>
        <inputEntry>
          <text>-</text>
        </inputEntry>
        <outputEntry>
          <text>No</text>
        </outputEntry>
      </rule>
      <rule>
        <inputEntry>
          <text>-</text>
        </inputEntry>
        <inputEntry>
          <text>&quot;Rain&quot;</text>
        </inputEntry>
        <inputEntry>
          <text>&quot;Strong&quot;</text>
        </inputEntry>
        <outputEntry>
          <text>No</text>
        </outputEntry>
      </rule>
      <rule>
        <inputEntry>
          <text>-</text>
        </inputEntry>
        <inputEntry>
          <text>&quot;Overcast&quot;</text>
        </inputEntry>
        <inputEntry>
          <text>-</text>
        </inputEntry>
        <outputEntry>
          <text>Yes</text>
        </outputEntry>
      </rule>
      <rule>
        <inputEntry>
          <text>&quot;Normal&quot;</text>
        </inputEntry>
        <inputEntry>
          <text>-</text>
        </inputEntry>
        <inputEntry>
          <text>&quot;Weak&quot;</text>
        </inputEntry>
        <outputEntry>
          <text>Yes</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
